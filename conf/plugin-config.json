{
  "knowledge_engine_endpoint": "http://localhost:8280/rest",
  "knowledge_base": {
    "id": "https://example.org/a-knowledge-base",
    "name": "Some knowledge base",
    "description": "This is just an example."
  },

  "plugin": {
    "class": "knowledge_mapper.plugins.example.ExampleDataSource",
    "args": ["https://example.org/something"]
  },

  "knowledge_interactions": [
    {
      "type": "answer",
      "vars": ["a", "b"],
      "prefixes": {
        "ex": "https://example.org/"
      },
      "pattern": "?a ex:isRelatedTo ?b ."
    }
  ]
}