{
  "knowledge_engine_endpoint": "http://localhost:8280/rest",
  "knowledge_base": {
    "id": "https://example.org/a-sql-knowledge-base",
    "name": "Some SQL knowledge base",
    "description": "This is just an example."
  },

  "sql_host": "127.0.0.1",
  "sql_port": 3306,
  "sql_database": "treedb",
  "sql_user": "user",
  "sql_password": "pw",

  "knowledge_interactions": [
    {
      "type": "answer",
      "column_prefixes": {
        "tree": "http://example.org/trees/"
      },
      "vars": ["tree", "height", "name"],
      "pattern": "?tree <https://example.org/hasHeight> ?height . ?tree <https://example.org/hasName> ?name .",
      "sql_query": "SELECT id AS tree, height, name FROM trees"
    },
    {
      "type": "react",
      "column_prefixes": {
        "tree": "http://example.org/trees/"
      },
      "vars": ["tree", "height", "name"],
      "argument_pattern": "?tree <https://example.org/hasHeight> ?height . ?tree <https://example.org/hasName> ?name .",
      "result_pattern": null,
      "sql_query": [
        {
          "statement": "INSERT INTO trees (id, height, name) VALUES (?, ?, ?)",
          "bindings": ["tree", "height", "name"]
        }
      ]
    }
  ]
}